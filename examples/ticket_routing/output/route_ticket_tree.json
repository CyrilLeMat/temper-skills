      "gray_zone": null
    },
    {
      "condition": "category == \"billing\"",
      "outcome": "route_billing",
      "rounds_survived": 6,
      "sources": ["domain_expert"],
      "critic_note": null,
      "gray_zone": null
    },
    {
      "condition": "category == \"bug\"",
      "outcome": "route_engineering",
      "rounds_survived": 6,
      "sources": ["domain_expert"],
      "critic_note": "account/feature_request/other collapse into the default — not enumerated (overengineering_critic)",
